{
  "name": "knowledge-keeper",
  "version": "0.3.0",
  "description": "个人知识管理工具 - 文档和视频整理、搜索、AI 识别",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:python": "pyinstaller --onedir --distpath python_backend/dist --name backend python_backend/run.py",
    "build:app": "tsc --noEmit && vite build && electron-builder",
    "build:dist": "npm run build:python && npm run build:app",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx"
  },
  "build": {
    "appId": "com.knowledge-keeper.app",
    "productName": "知识管家",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "python_backend/dist/backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "知识管家"
    }
  },
  "dependencies": {
    "antd": "^5.22.0",
    "@ant-design/icons": "^5.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.13"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
